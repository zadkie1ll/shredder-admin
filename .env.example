SHREDDER_ADMIN_HOST=0.0.0.0
SHREDDER_ADMIN_PORT=8015
SHREDDER_ADMIN_PUBLIC_PORT=8015

# Use the same Postgres database as the bot/site.
SHREDDER_ADMIN_DATABASE_URL=postgresql+psycopg2://user:password@postgres:5432/db

# Optional. If set, API calls must pass X-Admin-Token.
SHREDDER_ADMIN_TOKEN=

# Optional. If set, browser UI is protected with HTTP Basic Auth.
SHREDDER_ADMIN_UI_USERNAME=
SHREDDER_ADMIN_UI_PASSWORD=

# Optional initial seed. Used only when admin_config_templates is empty.
SHREDDER_ADMIN_SEED_TEMPLATE_PATH=/app/seed/template.json
